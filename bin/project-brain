#!/usr/bin/env node
import { execFileSync } from "child_process";
import { createRequire } from "module";
import { join } from "path";

const require = createRequire(import.meta.url);

const pkgMap = {
  "darwin-arm64": "project-brain-darwin-arm64",
  "linux-x64":    "project-brain-linux-x64",
  "linux-arm64":  "project-brain-linux-arm64",
  "win32-x64":    "project-brain-windows-x64",
  "win32-arm64":  "project-brain-windows-arm64",
};

const key = `${process.platform}-${process.arch}`;
const pkgName = pkgMap[key];

if (!pkgName) {
  console.error(`project-brain: unsupported platform ${key}`);
  process.exit(1);
}

let pkgDir;
try {
  pkgDir = join(require.resolve(`${pkgName}/package.json`), "..");
} catch {
  console.error(`project-brain: platform package "${pkgName}" not installed. Reinstall project-brain.`);
  process.exit(1);
}

const ext = process.platform === "win32" ? ".exe" : "";
// execFileSync throws whenever the child exits non-zero — a legitimate,
// expected outcome now that sync/reindex exit 1 on partial embed failure.
// Propagate the child's exit code/signal quietly instead of letting Node
// print a stack trace that buries the child's own error message.
try {
  execFileSync(join(pkgDir, "bin", `project-brain-native${ext}`), process.argv.slice(2), {
    stdio: "inherit",
    // lancedb's native addon reads this once at process start, not lazily —
    // it must already be in the CHILD's OS environment before it boots.
    // Setting process.env mid-process (in this parent, or inside cli.ts)
    // is too late and the "vector index statistics include centroids" WARN
    // still fires.
    env: { ...process.env, LANCE_INCLUDE_VECTOR_CENTROIDS: process.env.LANCE_INCLUDE_VECTOR_CENTROIDS ?? "false" },
  });
} catch (err) {
  if (err && typeof err.status === "number") process.exit(err.status);
  if (err && err.signal) process.exit(1);
  throw err; // genuine spawn failure (ENOENT, EACCES) — keep the diagnostic
}
