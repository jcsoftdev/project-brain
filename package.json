{
  "name": "project-brain",
  "version": "0.13.0",
  "type": "module",
  "description": "Local-first MCP server that gives AI tools semantic memory of your codebase.",
  "author": "jcsoftdev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jcsoftdev/project-brain.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "rag",
    "codebase",
    "embeddings",
    "lancedb",
    "ollama"
  ],
  "files": [
    "bin",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "project-brain": "bin/project-brain"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "setup": "bun run src/cli.ts setup",
    "init": "bun run src/cli.ts init",
    "build": "bun build ./src/cli.ts ./src/parser/worker.ts --compile --outfile dist/project-brain"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@clack/prompts": "^1.7.0",
    "@lancedb/lancedb": "^0.30.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ollama": "^0.6.3",
    "web-tree-sitter": "^0.25.10",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "project-brain-darwin-arm64": "*",
    "project-brain-linux-x64": "*",
    "project-brain-linux-arm64": "*",
    "project-brain-windows-x64": "*",
    "project-brain-windows-arm64": "*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "tree-sitter-wasms": "0.1.13",
    "typescript": "^5.5.4"
  }
}
